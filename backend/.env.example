# ShiroScan Backend Environment Variables
# Copy this file to .env or use the root .env file.

APP_ENV=development
LOG_LEVEL=INFO

# AI Provider API Keys (REQUIRED)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Provider Settings
OCR_PROVIDER=auto
LLM_PROVIDER=auto

# Application Limits
MAX_UPLOAD_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/heic

# CORS
CORS_ALLOWED_ORIGINS=*

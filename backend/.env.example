# ShiroScan backend environment variables.
# Copy to .env and fill values. Mock mode runs fine with no keys at all.

APP_ENV=development
LOG_LEVEL=INFO

# Upload limits
MAX_UPLOAD_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/heic

# AI provider keys (optional). When unset, providers fall back to mock/template.
GEMINI_API_KEY=
GROQ_API_KEY=

# Provider selection: "auto" picks the first provider whose API key is set,
# falling back to mock. Force a specific provider with: mock | gemini | groq | template
OCR_PROVIDER=auto
LLM_PROVIDER=auto

# CORS — comma-separated list of allowed origins. "*" allows any.
CORS_ALLOWED_ORIGINS=*
